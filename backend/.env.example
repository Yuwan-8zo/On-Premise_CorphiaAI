# ==================================
# Corphia AI Backend - 環境設定範例
# ==================================
# 1. 複製本檔為 backend/.env 後再修改
# 2. 產生安全的 SECRET_KEY:
#      python -c "import secrets; print(secrets.token_urlsafe(64))"
# ==================================

# ---------- 應用程式 ----------
APP_NAME=CorphiaAI
# development / production
APP_ENV=development
DEBUG=true

# ---------- 資料庫（PostgreSQL + pgvector，由 docker-compose 提供）----------
# 注意：本機開發走 host port 5433（docker-compose 的對外 port）
# 容器內互通請走 docker-compose 的 service name + 5432（已由 docker-compose 覆寫）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5433/corphia
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ---------- JWT 認證 ----------
# 生產環境必改！使用預設值會被 main.py 啟動檢查拒絕
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ---------- 本地 LLM（llama-cpp-python）----------
# 絕對路徑或相對於 backend/ 的路徑都可以
LLAMA_MODEL_PATH=../ai_model/Qwen2.5-7B-Instruct-Q5_K_M.gguf
LLAMA_CONTEXT_SIZE=4096
# 0 = 純 CPU；99 = 全層卸載到 GPU（需自編 llama-cpp-python 含 CUDA/Vulkan）
LLAMA_N_GPU_LAYERS=0

# ---------- Ollama（選用，未啟用時可留空）----------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# ---------- 上傳與檔案 ----------
UPLOAD_DIRECTORY=./uploads
MAX_UPLOAD_SIZE_MB=50

# ---------- CORS ----------
# 生產環境請列出實際 domain
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- 速率限制 ----------
RATE_LIMIT_ENABLED=true
# 全域每分鐘最大請求數
RATE_LIMIT_GLOBAL_MAX=120
# 登入每分鐘最大嘗試次數
RATE_LIMIT_LOGIN_MAX=10
# 註冊每小時最大次數
RATE_LIMIT_REGISTER_MAX=5

# ---------- 差異化功能開關（Corphia 專屬）----------
# PII 敏感資訊自動遮罩
ENABLE_PII_MASKING=true
# Prompt Injection 偵測
ENABLE_PROMPT_INJECTION_GUARD=true
# DLP 話題黑名單（管理員在 /admin 設定）
ENABLE_DLP=true
# DLP 關鍵字黑名單（逗號分隔）
DLP_BLOCKLIST=最高機密,絕對機密,top secret,classified secret
# 每使用者每日 Token 配額（0 = 不限）
DEFAULT_DAILY_TOKEN_QUOTA=100000

# ---------- RAG 進階設定 ----------
# 檢索 Top-K
RAG_TOP_K=5
# 最低相似度門檻（0~1；低於則視為不相關）
RAG_SIMILARITY_THRESHOLD=0.25
# Hybrid Search 的 BM25 權重（0=純向量，1=純 BM25）
RAG_BM25_WEIGHT=0.3
