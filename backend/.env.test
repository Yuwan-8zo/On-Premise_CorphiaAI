# 測試環境變數（使用獨立測試資料庫，避免污染正式資料）
# IMPORTANT: 請確認 corphia_test 資料庫已建立

# 測試資料庫（獨立的 corphia_test）
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/corphia_test
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/corphia_test

# JWT（測試用，可使用簡短金鑰）
SECRET_KEY=test-secret-key-for-testing-only
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# 應用程式模式
APP_ENV=test
DEBUG=false

# 關閉速率限制（避免影響測試）
RATE_LIMIT_ENABLED=false

# 上傳目錄（測試用臨時目錄）
UPLOAD_DIRECTORY=./test_uploads

# 關閉 LLM（測試不需要真實推論）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=test-model

# 安全功能（測試時保持開啟以驗證功能）
ENABLE_PII_MASKING=true
ENABLE_PROMPT_INJECTION_GUARD=true
ENABLE_DLP=true
