# ==================================
# Corphia AI Frontend - 環境設定範例
# ==================================
# 1. 複製本檔為 frontend/.env 或 frontend/.env.local
# 2. dev 直接走 Vite proxy 即可（不用設）；ngrok / 自訂網域才需要覆寫
# ==================================

# 後端 API base URL
# 預設值：/api/v1（透過 Vite dev server proxy 或同 domain 部署）
# 跨網域 / ngrok 場景請改為完整 URL，例如：https://your-ngrok.ngrok-free.app/api/v1
VITE_API_BASE_URL=/api/v1

# WebSocket URL（聊天串流）
# 預設值：自動由 window.location 推導
# 跨網域場景請設為 ws(s)://your-host
# VITE_WS_URL=ws://localhost:8168
